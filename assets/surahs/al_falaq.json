{
  "id": "al_falaq",
  "ayahs": [
    {
      "arabic": "بِسْمِ اللَّهِ الرَّحْمَٰنِ الرَّحِيمِ",
      "transliteration": "Bismillahir rahmanir rahim",
      "translation_key": "surah.al_falaq.0",
      "translation": "In the name of Allah, the Most Gracious, the Most Merciful"
    },
    {
      "arabic": "قُلْ أَعُوذُ بِرَبِّ الْفَلَقِ",
      "transliteration": "QuI a'oothu birabbil falaq",
      "translation_key": "surah.al_falaq.1",
      "translation": "Say: I seek refuge with the Lord of the daybreak"
    },
    {
      "arabic": "مِن شَرِّ مَا خَلَقَ",
      "transliteration": "Min sharri maa khalaq",
      "translation_key": "surah.al_falaq.2",
      "translation": "From the evil of what He has created"
    },
    {
      "arabic": "وَمِن شَرِّ غَاسِقٍ إِذَا وَقَبَ",
      "transliteration": "Wamin sharri ghasiqin ithaa waqab",
      "translation_key": "surah.al_falaq.3",
      "translation": "And from the evil of the darkening (night) as it comes with its darkness"
    },
    {
      "arabic": "وَمِن شَرِّ النَّفَّاثَاتِ فِي الْعُقَدِ",
      "transliteration": "Wamin sharrin-naffaathaati fil'uqad",
      "translation_key": "surah.al_falaq.4",
      "translation": "And from the evil of the witchcraft when they blow in the knots"
    },
    {
      "arabic": "وَمِن شَرِّ حَاسِدٍ إِذَا حَسَدَ",
      "transliteration": "Wamin sharri haasidin ithaa hasad",
      "translation_key": "surah.al_falaq.5",
      "translation": "And from the evil of the envier when he envies"
    }
  ]
}
